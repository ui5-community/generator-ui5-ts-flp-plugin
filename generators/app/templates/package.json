{
  "name": "<%= namespace %>",
  "version": "1.0.0",
  "description": "Fiori Plugin: <%= namespace %>",
  "author": "<%= author %>",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "ui5 build --clean-dest",
    "build:opt": "ui5 build self-contained --clean-dest --all",
    "start": "ui5 serve --port 8080 --config ui5-test.yaml -o test/flpSandbox.html",
    "ts-typecheck": "tsc --noEmit",
    "lint": "eslint webapp",
    "ui5lint": "ui5lint",
    "test-ui5": "ui5-test-runner --start start-coverage --url http://localhost:8080/test/testsuite.qunit.html --coverage -ccb 50 -ccf 50 -ccl 50 -ccs 50",
    "test": "npm run lint && npm run test-ui5"
  },
  "devDependencies": {
    "<%= tstypes %>": "<%= tstypesVersion %>",
    "@ui5/cli": "^4.0.26",
    "@ui5/linter": "^1.20.0",
    "babel-plugin-istanbul": "^7.0.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "ui5-middleware-livereload": "^3.1.4",
    "ui5-tooling-transpile": "^3.9.2"
  }
}
