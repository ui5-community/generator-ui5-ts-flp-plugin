{
  "name": "<%= namespace %>",
  "version": "1.0.0",
  "description": "Flp Plugin: <%= namespace %>",
  "author": "<%= author %>",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "ui5 build --clean-dest",
    "build:opt": "ui5 build self-contained --clean-dest --all",
    "start": "ui5 serve --port 8080 -o flpSandbox.html",
    "start-cdn": "ui5 serve --port 8080 -o flpSandbox-cdn.html",
    "start:dist": "npm start -- --config ui5-dist.yaml",
    "start:dist-cdn": "npm run start-cdn -- --config ui5-dist.yaml",
    "lint": "eslint webapp",
    "test": "cd test && yo ../generators/app/index.js",
    "prepare": "node ./.husky/skip.js || husky",
    "hooks:pre-commit": "npm run format:staged && npm run lint:staged"
  },
  "devDependencies": {
    "<%= tstypes %>": "<%= tstypesVersion %>",
    "@ui5/cli": "latest",
    "@ui5/middleware-code-coverage": "latest",
    "eslint": "^9.9.1",
    "eslint-plugin-jsdoc": "^50.2.2",
    "globals": "^15.9.0",
    "rimraf": "^6.0.1",
    "ui5-middleware-livereload": "latest",
    "@prettier/plugin-xml": "^3.4.2"
  }
}
